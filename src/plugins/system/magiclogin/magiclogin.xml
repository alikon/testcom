<?xml version="1.0" encoding="UTF-8"?>
<extension type="plugin" group="system" method="upgrade">
    <name>plg_system_magiclogin</name>
    <author>Alikon</author>
    <creationDate>2026-01</creationDate>
    <copyright>(C) 2007 Alikonweb</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <authorEmail>alikon@alikonweb.it</authorEmail>
    <authorUrl>www.alikonweb.it</authorUrl>
    <version>1.0.0</version>
    <description>PLG_SYSTEM_MAGICLOGIN_XML_DESCRIPTION</description>
    <namespace path="src">Joomla\Plugin\System\MagicLogin</namespace>
    <!-- Scripts to run on installation -->
	<scriptfile>script.php</scriptfile>
    <files>
        <folder plugin="magiclogin">services</folder>
        <folder>src</folder>
        <folder>language</folder>
        <folder>field</folder>
    </files>

    <config>
        <fields name="params"  addfieldpath="/plugins/system/magiclogin/field">
            <fieldset name="basic">
                <field name="license" type="note" 
                    label="PLG_SYSTEM_MAGICLOGIN_GPL_LICENSE" 
                    description=""
                    class="alert alert-success" />
                
                <field name="plugin_links" type="links" label="PLG_SYSTEM_MAGICLOGIN_LINKS_LABEL" />
                <field name="plugin_version" type="version" label="PLG_SYSTEM_MAGICLOGIN_VERSION_LABEL" />
                <field name="token_expiry" 
                       type="number" 
                       default="15" 
                       label="PLG_SYSTEM_MAGICLOGIN_TOKEN_EXPIRY_LABEL" 
                       description="PLG_SYSTEM_MAGICLOGIN_TOKEN_EXPIRY_DESC" 
                       min="5" 
                       max="1440" />
                
                <field name="rate_limit_enabled"
                       type="radio"
                       label="PLG_SYSTEM_MAGICLOGIN_RATE_LIMIT_ENABLED_LABEL"
                       description="PLG_SYSTEM_MAGICLOGIN_RATE_LIMIT_ENABLED_DESC"
                       default="1"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="rate_limit_max_attempts"
                       type="number"
                       label="PLG_SYSTEM_MAGICLOGIN_RATE_LIMIT_MAX_ATTEMPTS_LABEL"
                       description="PLG_SYSTEM_MAGICLOGIN_RATE_LIMIT_MAX_ATTEMPTS_DESC"
                       default="3"
                       min="1"
                       max="10"
                       showon="rate_limit_enabled:1" />

                <field name="rate_limit_window"
                       type="number"
                       label="PLG_SYSTEM_MAGICLOGIN_RATE_LIMIT_WINDOW_LABEL"
                       description="PLG_SYSTEM_MAGICLOGIN_RATE_LIMIT_WINDOW_DESC"
                       default="5"
                       min="1"
                       max="60"
                       showon="rate_limit_enabled:1" />
            </fieldset>
        </fields>
    </config>
    <changelogurl>https://raw.githubusercontent.com/alikon/testcom/main/src/plugins/system/magiclogin/changelog.xml</changelogurl>
    <updateservers>
		<server type="extension" name="System - Magic Login">https://raw.githubusercontent.com/alikon/testcom/main/src/plugins/system/magiclogin/updateserver.xml</server>
	</updateservers>
</extension>
