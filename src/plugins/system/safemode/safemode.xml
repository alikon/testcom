<?xml version="1.0" encoding="UTF-8"?>
<extension type="plugin" group="system" method="upgrade">
    <name>plg_system_safemode</name>
    <version>1.0.0</version>
    <creationDate>2026-01</creationDate>
    <author>Alikon</author>
    <copyright>(C) 2026 Alikonweb</copyright>
    <license>GNU General Public License version 2 or later</license>
    <authorEmail>optimus4joomla@gmail.com</authorEmail>
    <authorUrl>www.alikonweb.it</authorUrl>
    <description>PLG_SYSTEM_SAFEMODE_XML_DESCRIPTION</description>
    
    <namespace path="src">Joomla\Plugin\System\Safemode</namespace>
    
    <files>
        <folder plugin="safemode">services</folder>
        <folder>src</folder>
        <folder>field</folder>
        <folder>language</folder>
    </files>
    
    <config>
        <fields name="params" addfieldpath="/plugins/system/safemode/field">
            <fieldset name="basic">
                <field name="license" type="note" 
                    label="PLG_SYSTEM_SAFEMODE_GPL_LICENSE" 
                    description=""
                    class="alert alert-success" />
                
                <field name="plugin_links" type="links" label="PLG_SYSTEM_SAFEMODE_LINKS_LABEL" />
                <field name="plugin_version" 
                   type="version" 
                   label="PLG_SYSTEM_SAFEMODE_VERSION_LABEL" />
                <field
                    name="enabled_ui"
                    type="radio"
                    label="PLG_SYSTEM_SAFEMODE_FIELD_ENABLED_UI_LABEL"
                    description="PLG_SYSTEM_SAFEMODE_FIELD_ENABLED_UI_DESC"
                    default="0"
                    class="btn-group btn-group-yesno"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                
                <field
                    name="dry_run"
                    type="radio"
                    label="PLG_SYSTEM_SAFEMODE_FIELD_DRY_RUN_LABEL"
                    description="PLG_SYSTEM_SAFEMODE_FIELD_DRY_RUN_DESC"
                    default="0"
                    class="btn-group btn-group-yesno"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>
