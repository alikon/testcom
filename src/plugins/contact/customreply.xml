<?xml version="1.0" encoding="UTF-8"?>
<extension type="plugin" group="contact" method="upgrade">
    <name>plg_contact_customreply</name>
    <author>Alikon</author>
    <creationDate>2026-05</creationDate>
    <copyright>(C) 2007 Alikonweb</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <authorEmail>alikon@alikonweb.it</authorEmail>
    <authorUrl>www.alikonweb.it</authorUrl>
    <version>1.0.0</version>
    <description>PLG_CONTACT_CUSTOMREPLY_XML_DESCRIPTION</description>
    <namespace path="src">Joomla\Plugin\Contact\CustomReply</namespace>
    <!-- Scripts to run on installation -->
	<scriptfile>script.php</scriptfile>
    <files>
        <folder plugin="customreply">services</folder>
        <folder>src</folder>
        <folder>language</folder>
        <folder>field</folder>
    </files>

    <config>
        <fields name="params"  addfieldpath="/plugins/contact/customreply/field" addfieldprefix="Joomla\Component\Menus\Administrator\Field">
            <fieldset name="basic">
                <field name="license" type="note" 
                    label="PLG_CONTACT_CUSTOMREPLY_GPL_LICENSE" 
                    description=""
                    class="alert alert-success" />
                
                <field name="plugin_links" type="links" label="PLG_CONTACT_CUSTOMREPLY_LINKS_LABEL" />
                <field name="plugin_version" type="version" label="PLG_CONTACT_CUSTOMREPLY_VERSION_LABEL" />   
                <field
                    name="redirect_url"
                    type="modal_menu"
                    label="PLG_CONTACT_CUSTOMREPLY_REDIRECT_URL_LABEL"
                    description="PLG_CONTACT_CUSTOMREPLY_REDIRECT_URL_DESC"
                    disable="separator,alias,heading,url"
                    select="true"
                    new="true"
                    edit="true"
                    clear="true"
                    >
                    <option value="">JOPTION_SELECT_MENU_ITEM</option>
                </field>             
            </fieldset>
        </fields>
    </config>
    <changelogurl>https://raw.githubusercontent.com/alikon/testcom/main/src/plugins/contact/customreply/changelog.xml</changelogurl>
    <updateservers>
		<server type="extension" name="Contact - Custom Reply">https://raw.githubusercontent.com/alikon/testcom/main/src/plugins/contact/customreply/updateserver.xml</server>
	</updateservers>
</extension>
