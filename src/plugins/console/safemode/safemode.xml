<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="console" method="upgrade">
    <name>PLG_CONSOLE_SAFEMODE</name>
    <author>Alikon</author>
    <creationDate>2026-01</creationDate>
    <copyright>(C) 2007 Alikonweb</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <authorEmail>alikon@alikonweb.it</authorEmail>
    <authorUrl>www.alikonweb.it</authorUrl>
    <version>1.0.1</version>
    <description>PLG_CONSOLE_SAFEMODE_XML_DESCRIPTION</description>

    <!-- Correct namespace per Joomla docs -->
    <namespace path="src">Joomla\Plugin\Console\Safemode</namespace>
    <changelogurl>https://raw.githubusercontent.com/alikon/testcom/main/src/plugins/console/safemode/changelog.xml</changelogurl>
    <files>
        <!-- Services directory must be included -->
        <folder plugin="safemode">services</folder>
        <!-- src directory for your plugin code -->
        <folder>src</folder>
        <folder>language</folder>
        <folder>field</folder>
    </files>
    <config>
        <fields name="params" addfieldpath="/plugins/console/safemode/field">
            <fieldset name="basic">
                <field name="license" type="note" 
                    label="PLG_CONSOLE_SAFEMODE_GPL_LICENSE" 
                    description=""
                    class="alert alert-success" />
                
                <field name="plugin_links" type="links" label="PLG_CONSOLE_SAFEMODE_LINKS_LABEL" />
                <field name="plugin_version" type="version" label="PLG_CONSOLE_SAFEMODE_VERSION_LABEL" />                
            </fieldset>
        </fields>
    </config>
    <updateservers>
        <server type="extension" name="Console - Safemode">https://raw.githubusercontent.com/alikon/testcom/main/src/plugins/console/safemode/updateserver.xml</server>
    </updateservers>
</extension>
